<!DOCTYPE html>

<html>
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width"/>
<title>Invoice</title>
</head>

<body style="margin:0;background:#eef2f7;font-family:Segoe UI,Arial,sans-serif;">

<table width="100%" cellpadding="0" cellspacing="0" style="padding:30px 10px;">
<tr>
<td align="center">

<table width="620" cellpadding="0" cellspacing="0"
style="background:#ffffff;border-radius:14px;overflow:hidden;
box-shadow:0 12px 40px rgba(0,0,0,.08);">

<!-- HEADER -->

<tr>
<td style="background:linear-gradient(135deg,#4f46e5,#06b6d4);
padding:40px;text-align:center;color:white;">

<div style="font-size:32px;font-weight:700;">INVOICE</div>
<div style="opacity:.9;margin-top:6px;font-size:14px;">
PH Healthcare Payment Receipt
</div>

</td>
</tr>

<!-- BODY -->

<tr>
<td style="padding:35px;">

<p style="font-size:17px;color:#111;">
Hello <strong><%= patientName %></strong>,
</p>

<p style="margin-top:8px;color:#666;font-size:14px;">
Your payment has been successfully processed.  
Here is your official invoice summary.
</p>

<!-- INVOICE CARD -->

<div style="margin-top:28px;border:1px solid #edf1f5;
border-radius:10px;padding:22px;background:#fafbfc;">

<div style="display:flex;justify-content:space-between;font-size:14px;margin-bottom:10px;">
<span style="color:#666;">Invoice ID</span>
<strong><%= invoiceId %></strong>
</div>

<div style="display:flex;justify-content:space-between;font-size:14px;margin-bottom:10px;">
<span style="color:#666;">Transaction</span>
<span><%= transactionId %></span>
</div>

<div style="display:flex;justify-content:space-between;font-size:14px;margin-bottom:10px;">
<span style="color:#666;">Payment Date</span>
<span><%= paymentDate %></span>
</div>

<div style="display:flex;justify-content:space-between;font-size:14px;">
<span style="color:#666;">Status</span>
<span style="color:#16a34a;font-weight:600;">✔ PAID</span>
</div>

</div>

<!-- CONSULTATION -->

<div style="margin-top:24px;border:1px solid #edf1f5;
border-radius:10px;padding:22px;">

<div style="font-size:13px;font-weight:700;color:#4f46e5;
text-transform:uppercase;margin-bottom:10px;">
Consultation Details
</div>

<div style="font-size:14px;margin-bottom:6px;">
<strong>Doctor:</strong> <%= doctorName %>
</div>

<div style="font-size:14px;">
<strong>Appointment:</strong> <%= appointmentDate %>
</div>

</div>

<!-- AMOUNT -->

<div style="margin-top:28px;
background:linear-gradient(135deg,#4f46e5,#06b6d4);
border-radius:12px;padding:28px;text-align:center;color:white;">

<div style="font-size:13px;opacity:.9;">Total Amount Paid</div>

<div style="font-size:38px;font-weight:700;margin-top:6px;">
<%= amount.toFixed(2) %> BDT
</div>

</div>

<!-- CTA -->

<% if (invoiceUrl) { %>

<div style="text-align:center;margin-top:30px;">
<a href="<%= invoiceUrl %>"
style="background:#111827;color:white;text-decoration:none;
padding:14px 34px;border-radius:8px;font-size:15px;
font-weight:600;display:inline-block;">
⬇ Download Invoice PDF
</a>
</div>
<% } %>

<!-- NOTE -->

<div style="margin-top:28px;background:#f8fafc;
padding:16px;border-radius:8px;font-size:13px;color:#555;">
Your appointment is confirmed.  
Please login to your dashboard for full consultation details.
</div>

</td>
</tr>

<!-- FOOTER -->

<tr>
<td style="background:#f3f4f6;padding:26px;text-align:center;
font-size:12px;color:#777;">

<div style="font-weight:600;">PH Healthcare</div>
<div style="margin-top:6px;">Your Health, Our Priority</div>

<div style="margin-top:14px;">
https://ph-healthcare.com
</div>

<div style="margin-top:10px;font-size:11px;color:#999;">
Automated email • Please do not reply
</div>

</td>
</tr>

</table>

</td>
</tr>
</table>

</body>
</html>

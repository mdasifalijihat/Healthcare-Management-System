<!DOCTYPE html>

<html>
  <head>
    <meta charset="UTF-8" />
    <title>Email Verification</title>
  </head>

  <body
    style="
      margin: 0;
      padding: 0;
      background: #f4f7fb;
      font-family: Arial, Helvetica, sans-serif;
    "
  >
    <table width="100%" cellpadding="0" cellspacing="0">
      <tr>
        <td align="center">
          ```
          <table
            width="600"
            cellpadding="0"
            cellspacing="0"
            style="
              background: #ffffff;
              border-radius: 10px;
              overflow: hidden;
              margin-top: 40px;
              box-shadow: 0 4px 10px rgba(0, 0, 0, 0.05);
            "
          >
            <!-- Header -->
            <tr>
              <td
                style="
                  background: #2b7cff;
                  padding: 20px;
                  text-align: center;
                  color: #fff;
                "
              >
                <h2 style="margin: 0">HealthCare System</h2>
                <p style="margin: 5px 0 0; font-size: 14px">
                  Doctor • Patient • Appointment
                </p>
              </td>
            </tr>

            <!-- Body -->
            <tr>
              <td style="padding: 30px 40px">
                <h3 style="margin-top: 0; color: #333">Hello <%= name %>,</h3>

                <p style="color: #555; font-size: 15px; line-height: 1.6">
                  Welcome to our healthcare platform. To complete your
                  registration and verify your email address, please use the OTP
                  code below.
                </p>

                <!-- OTP Box -->
                <div style="text-align: center; margin: 30px 0">
                  <div
                    style="
                      display: inline-block;
                      background: #f1f6ff;
                      padding: 15px 30px;
                      font-size: 28px;
                      letter-spacing: 6px;
                      font-weight: bold;
                      color: #2b7cff;
                      border-radius: 8px;
                      border: 1px dashed #2b7cff;
                    "
                  >
                    <%= otp %>
                  </div>
                </div>

                <p style="text-align: center; color: #666; font-size: 14px">
                  This OTP will expire in <b>2 minutes</b>.
                </p>

                <p
                  style="
                    color: #555;
                    font-size: 14px;
                    line-height: 1.6;
                    margin-top: 25px;
                  "
                >
                  If you did not request this verification, you can safely
                  ignore this email.
                </p>

                <p style="margin-top: 30px; color: #333; font-size: 14px">
                  Regards,<br />
                  <b>HealthCare Team</b>
                </p>
              </td>
            </tr>

            <!-- Footer -->
            <tr>
              <td
                style="
                  background: #f4f7fb;
                  padding: 15px;
                  text-align: center;
                  font-size: 12px;
                  color: #888;
                "
              >
                © <%= new Date().getFullYear() %> HealthCare System. All rights
                reserved.
              </td>
            </tr>
          </table>
        </td>
      </tr>
      ```
    </table>
  </body>
</html>

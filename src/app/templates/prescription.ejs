<!DOCTYPE html>

<html>
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Prescription</title>
</head>

<body style="margin:0;padding:0;background:#f4f7fb;font-family:Segoe UI,Arial,sans-serif;">

<table width="100%" cellpadding="0" cellspacing="0" style="background:#f4f7fb;padding:30px 0;">
<tr>
<td align="center">

<table width="600" cellpadding="0" cellspacing="0" style="background:#ffffff;border-radius:12px;overflow:hidden;box-shadow:0 8px 25px rgba(0,0,0,.08);">

<!-- HEADER -->

<tr>
<td style="background:linear-gradient(135deg,#0d6efd,#0dcaf0);padding:30px;text-align:center;color:white;">
<h1 style="margin:0;font-size:30px;">📋 Prescription</h1>
<p style="margin-top:8px;font-size:14px;opacity:.9;">PH Healthcare Services</p>
</td>
</tr>

<!-- BODY -->

<tr>
<td style="padding:35px;">

<p style="font-size:16px;color:#333;">
Dear <strong><%= patientName %></strong>,
</p>

<p style="font-size:14px;color:#666;margin-top:8px;">
Your prescription has been successfully issued. Please review the details below.
</p>

<!-- Doctor Card -->

<div style="margin-top:30px;border:1px solid #eef1f5;border-radius:8px;padding:20px;">
<p style="margin:0;font-size:13px;color:#0d6efd;font-weight:bold;text-transform:uppercase;">Doctor Information</p>

<p style="margin-top:12px;font-size:14px;">
<strong>Name:</strong> <%= doctorName %>
</p>

<p style="margin-top:6px;font-size:14px;">
<strong>Specialization:</strong> <%= specialization %>
</p>
</div>

<!-- Prescription Card -->

<div style="margin-top:20px;border:1px solid #eef1f5;border-radius:8px;padding:20px;">
<p style="margin:0;font-size:13px;color:#0d6efd;font-weight:bold;text-transform:uppercase;">Prescription Details</p>

<p style="margin-top:12px;font-size:14px;"><strong>ID:</strong> <%= prescriptionId %></p>
<p style="margin-top:6px;font-size:14px;"><strong>Appointment:</strong> <%= appointmentDate %></p>
<p style="margin-top:6px;font-size:14px;"><strong>Issued:</strong> <%= issuedDate %></p>

<% if (followUpDate) { %>

<p style="margin-top:6px;font-size:14px;"><strong>Follow-up:</strong> <%= followUpDate %></p>
<% } %>

</div>

<!-- Instruction Box -->

<div style="margin-top:25px;background:#f1f9ff;border-left:4px solid #0d6efd;padding:18px;border-radius:6px;">
<p style="margin:0;font-size:13px;font-weight:bold;color:#0d6efd;text-transform:uppercase;">
💊 Instructions & Medications
</p>

<p style="margin-top:10px;font-size:14px;color:#333;line-height:1.7;white-space:pre-wrap;">
<%= instructions %>
</p>
</div>

<!-- CTA -->

<% if (pdfUrl) { %>

<div style="margin-top:30px;text-align:center;">
<a href="<%= pdfUrl %>"
style="background:#0d6efd;color:white;text-decoration:none;padding:14px 32px;border-radius:6px;font-size:15px;font-weight:bold;display:inline-block;">
⬇ Download Prescription PDF
</a>
</div>
<% } %>

<!-- Warning -->

<div style="margin-top:30px;background:#fff4f4;padding:15px;border-radius:6px;font-size:13px;color:#c92a2a;">
<strong>⚠ Important:</strong> Follow your doctor’s instructions carefully. Contact your healthcare provider if needed.
</div>

</td>
</tr>

<!-- FOOTER -->

<tr>
<td style="background:#f8f9fa;padding:25px;text-align:center;font-size:12px;color:#777;">
<p style="margin:0;">Automated email from PH Healthcare Services</p>
<p style="margin-top:6px;">Visit: https://ph-healthcare.com</p>
</td>
</tr>

</table>

</td>
</tr>
</table>

</body>
</html>

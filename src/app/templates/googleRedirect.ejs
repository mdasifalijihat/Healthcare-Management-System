<!DOCTYPE html>
<html>
  <head>
    <meta charset="UTF-8" />
    <title>Google Login</title>

    <style>
      body {
        margin: 0;
        padding: 0;
        font-family: Arial, Helvetica, sans-serif;
        background: #f4f7fb;
        height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
      }

      .card {
        background: white;
        width: 420px;
        padding: 40px;
        border-radius: 12px;
        text-align: center;
        box-shadow: 0 10px 25px rgba(0, 0, 0, 0.08);
      }

      .logo {
        font-size: 22px;
        font-weight: bold;
        color: #2b7cff;
        margin-bottom: 10px;
      }

      .title {
        font-size: 20px;
        font-weight: bold;
        margin-bottom: 15px;
        color: #333;
      }

      .message {
        font-size: 14px;
        color: #666;
        margin-bottom: 30px;
      }

      .loader {
        width: 40px;
        height: 40px;
        border: 4px solid #e0e0e0;
        border-top: 4px solid #2b7cff;
        border-radius: 50%;
        animation: spin 1s linear infinite;
        margin: auto;
      }

      @keyframes spin {
        0% {
          transform: rotate(0deg);
        }
        100% {
          transform: rotate(360deg);
        }
      }

      .footer {
        margin-top: 25px;
        font-size: 12px;
        color: #999;
      }
    </style>
  </head>

  <body>
    <div class="card">
      <div class="logo">HealthCare System</div>

      <div class="title">Google Login Successful</div>

      <div class="message">
        Please wait while we redirect you to your dashboard...
      </div>

      <div class="loader"></div>

      <div class="footer">Secure authentication powered by Google</div>
    </div>

    <script>
      (async () => {
        try {
          const response = await fetch(
            "<%= betterAuthUrl %>/api/auth/sign-in/social",
            {
              method: "POST",
              headers: {
                "Content-Type": "application/json",
              },
              credentials: "include",
              body: JSON.stringify({
                provider: "google",
                callbackURL: "<%= callbackUrl %>",
              }),
            },
          );

          if (!response.ok) {
            throw new Error("Failed to start Google login");
          }

          const data = await response.json();

          if (data.url) {
            window.location.href = data.url;
          } else {
            document.body.innerHTML = `
              <div style="text-align:center;font-family:sans-serif">
                <h3>Google redirect URL not found</h3>
                <p>Please try again later</p>
              </div>
            `;
          }
        } catch (error) {
          document.body.innerHTML = `
            <div style="text-align:center;font-family:sans-serif">
              <h3>Error occurred while redirecting to Google</h3>
              <p>Please try again later</p>
              <p>${error.message}</p>
            </div>
          `;
        }
      })();
    </script>
  </body>
</html>
